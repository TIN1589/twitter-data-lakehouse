# =============================================================================
# Environment Variables — Twitter Data Lakehouse
# Target: AWS EC2 t3.micro (1GB RAM + 4GB Swap)
# =============================================================================

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=twitter-data
MINIO_ENDPOINT=minio:9000

# --- Superset ---
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=

# --- PostgreSQL (Airflow Metadata DB) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow Core (Optimized for 1GB RAM) ---
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__PARALLELISM=1
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=1
AIRFLOW_UID=50000

# --- Airflow Webserver (minimal workers to save RAM) ---
AIRFLOW__WEBSERVER__WORKERS=1
AIRFLOW__WEBSERVER__WORKER_REFRESH_INTERVAL=1800
AIRFLOW__WEBSERVER__WEB_SERVER_WORKER_TIMEOUT=300

# --- Airflow Scheduler (reduced frequency to save CPU) ---
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=60
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=120
AIRFLOW__SCHEDULER__PARSING_PROCESSES=1

# --- Airflow Database ---
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__DATABASE__LOAD_DEFAULT_CONNECTIONS=False

# --- Airflow Init ---
_AIRFLOW_DB_UPGRADE=True
_AIRFLOW_WWW_USER_CREATE=True
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
